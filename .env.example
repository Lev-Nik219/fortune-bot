# Создаем правильный .env.example без секретов
@"
# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_bot_token_here

# CryptoPay Token (получите у @CryptoPayBot)
CRYPTOPAY_TOKEN=your_cryptopay_token_here

# Hugging Face API Key (получите на huggingface.co)
HF_API_KEY=your_huggingface_key_here

# Режим тестирования (true/false)
TEST_MODE=false

# Использовать webhook (true/false)
USE_WEBHOOK=false

# URL на Render (будет установлен автоматически)
RENDER_URL=

# Стоимость предсказания в USDT
PRICE_USDT=0.10
"@ | Out-File -FilePath .env.example -Encoding UTF8